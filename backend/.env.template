AZURE_SQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=<your-server>.database.windows.net;Database=<your-db>;Uid=<username>;Pwd=<password>;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;

